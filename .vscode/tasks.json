{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "problemMatcher": [
    {
      "fileLocation": [
        "relative",
        "${workspaceFolder}/src"
      ],
      "owner": "cpp",
      "source": "C/C++",
      "pattern": {
        "regexp": "^(.*):(\\d+):\\s+(warning|error)\\s+(\\d+):\\s+(.*)$",
        "file": 1,
        "line": 2,
        "severity": 3,
        "message": 5
      }
    }
  ],
  "tasks": [
    {
      "label": "Build all (debug)",
      "detail": "Builds the project assets and sources sources to the build area. Uses development / debug environment profile",
      "type": "shell",
      "command": "make",
      "options": {
        "env": {
          "ENV": "debug"
        }
      },
      "presentation": {
        "revealProblems": "onProblem",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build all (release)",
      "detail": "Builds the project assets and sources sources to the build area. Uses release environment profile",
      "type": "shell",
      "command": "make -e ENV=release",
      "presentation": {
        "revealProblems": "onProblem",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Build assets (debug)",
      "detail": "Builds only the project assets to the assets intermediate build area. Uses development / debug environment profile",
      "type": "shell",
      "command": "make assets",
      "options": {
        "env": {
          "ENV": "debug"
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Build sources (debug)",
      "detail": "Builds only the project sources to the build area. Uses development / debug environment profile",
      "type": "shell",
      "command": "make build",
      "options": {
        "env": {
          "ENV": "debug"
        }
      },
      "presentation": {
        "revealProblems": "onProblem",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Clean",
      "detail": "Removes all generated files and build folders",
      "type": "shell",
      "command": "make clean",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}